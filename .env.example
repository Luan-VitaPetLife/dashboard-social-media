PORT=3000
# Seguidores/curtidas não mudam minuto a minuto — sync a cada 12h já é mais que suficiente.
SYNC_INTERVAL_MINUTES=720

# Ausente = usa data/db.json local. Presente = usa Postgres (Railway).
DATABASE_URL=

# Mesmo System User Token já usado no dashboard principal (live-dashboard) — as 4 contas
# abaixo vivem no mesmo Business Manager, então um token só serve pras quatro.
META_ACCESS_TOKEN=
META_GRAPH_VERSION=v20.0

# IDs das contas comerciais do Instagram (Business/Creator, vinculadas a uma Página do Facebook).
# Pegar via Graph API Explorer: GET /me/accounts?fields=id,name,instagram_business_account{id,username}
META_IG_ACCOUNT_ID_BR=
META_IG_ACCOUNT_ID_US=

# IDs das Páginas do Facebook (mesma chamada acima, campo "id" de cada item de /me/accounts).
META_FB_PAGE_ID_BR=
META_FB_PAGE_ID_US=

PORT=3000
# Seguidores/curtidas não mudam minuto a minuto — sync a cada 12h já é mais que suficiente.
SYNC_INTERVAL_MINUTES=720
# Stories vivem só 24h e somem da API assim que expiram — precisa de um ciclo bem mais curto
# que o sync normal pra ter chance de capturar cada um antes que suma.
STORY_SYNC_INTERVAL_MINUTES=120

# Login único compartilhado (liga/desliga em Configurações, desligado por padrão). Sem essa
# variável, o toggle de login recusa ligar (trava de segurança — senão ninguém conseguiria
# entrar de novo). SESSION_SECRET assina o cookie de sessão; se ausente, cai pra
# DASHBOARD_PASSWORD como segredo de assinatura (recomendado configurar os dois em produção).
DASHBOARD_PASSWORD=
SESSION_SECRET=

# As variáveis abaixo alimentam src/registry.js (empresa → marca → país → conta). Hoje só a
# marca Coco and Luna tem contas configuradas (Brasil + Estados Unidos) — adicionar uma marca ou
# país novo no futuro significa acrescentar um objeto em registry.js + as env vars correspondentes.

# Ausente = usa data/db.json local (some a cada deploy no Railway, sem Volume). Presente =
# usa MongoDB Atlas — tier grátis M0 (512MB), fora do orçamento medido do Railway.
# String de conexão do cluster, ex: mongodb+srv://user:senha@cluster0.xxxxx.mongodb.net/
MONGODB_URI=
MONGODB_DB=dashboard_social

# Mesmo System User Token já usado no dashboard principal (live-dashboard) — as 4 contas
# abaixo vivem no mesmo Business Manager, então um token só serve pras quatro.
META_ACCESS_TOKEN=
META_GRAPH_VERSION=v20.0

# IDs das contas comerciais do Instagram (Business/Creator, vinculadas a uma Página do Facebook).
# Pegar via Graph API Explorer: GET /me/accounts?fields=id,name,instagram_business_account{id,username}
META_IG_ACCOUNT_ID_BR=
META_IG_ACCOUNT_ID_US=

# IDs das Páginas do Facebook (mesma chamada acima, campo "id" de cada item de /me/accounts).
META_FB_PAGE_ID_BR=
META_FB_PAGE_ID_US=

# Contas de anúncio (mesmo Business Manager do projeto de vendas ../dashboard, reaproveita os
# mesmos valores de META_AD_ACCOUNT_ID/META_US_AD_ACCOUNT_ID de lá) — usadas só pra identificar
# conteúdo impulsionado na ficha de conteúdo (nunca gasto/ROAS, fora do escopo do Social Media).
META_AD_ACCOUNT_ID_BR=
META_AD_ACCOUNT_ID_US=

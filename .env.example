PORT=3000
# Seguidores/curtidas não mudam minuto a minuto — sync a cada 12h já é mais que suficiente.
SYNC_INTERVAL_MINUTES=720

# Ausente = usa data/db.json local. Presente = usa Postgres (Railway).
DATABASE_URL=

# Mesmo System User Token já usado no dashboard principal (live-dashboard).
META_ACCESS_TOKEN=
META_GRAPH_VERSION=v20.0

# ID da conta comercial do Instagram (Business/Creator Account conectada a uma Página do Facebook).
META_IG_ACCOUNT_ID=

# ID da Página do Facebook.
META_FB_PAGE_ID=
